{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macp.dev/schemas/macp-agent-manifest.schema.json",
  "title": "MACP Agent Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "description",
    "supported_modes",
    "input_content_types",
    "output_content_types"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "supported_modes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "input_content_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "output_content_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "transport_endpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TransportEndpoint"
      }
    }
  },
  "$defs": {
    "TransportEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transport",
        "uri",
        "content_types"
      ],
      "properties": {
        "transport": {
          "type": "string",
          "minLength": 1,
          "description": "Registered MACP transport identifier, e.g. macp.transport.grpc.v1"
        },
        "uri": {
          "type": "string",
          "minLength": 1,
          "description": "Network endpoint URI, e.g. grpcs://runtime.example.com:50051"
        },
        "content_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
