{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macp.dev/schemas/macp-envelope.schema.json",
  "title": "MACP Envelope (Canonical JSON Mapping)",
  "type": "object",
  "required": [
    "macp_version",
    "mode",
    "message_type",
    "message_id",
    "session_id",
    "sender",
    "timestamp"
  ],
  "properties": {
    "macp_version": {
      "type": "string",
      "minLength": 1,
      "description": "MACP protocol version (semantic versioning).",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?([-+][0-9A-Za-z.-]+)?$"
    },
    "mode": {
      "type": "string",
      "description": "Empty string for Ambient Signals; canonical mode identifier for session-scoped messages (for example macp.mode.decision.v1)."
    },
    "message_type": {
      "type": "string",
      "minLength": 1,
      "description": "Message type discriminator (e.g., Signal, SessionStart, Commitment)."
    },
    "message_id": {
      "type": "string",
      "minLength": 1,
      "description": "Globally unique message identifier (format is deployment-defined)."
    },
    "session_id": {
      "type": "string",
      "description": "Empty string for Ambient Signals; non-empty for session-scoped messages."
    },
    "sender": {
      "type": "string",
      "minLength": 1,
      "description": "Agent identifier for the sender."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 timestamp string (UTC recommended)."
    },
    "payload": {
      "description": "Decoded JSON payload form (preferred for Core payloads and readable messages)."
    },
    "payload_b64": {
      "type": "string",
      "description": "Opaque payload bytes encoded as base64 (use when payload is opaque or binary).",
      "contentEncoding": "base64"
    }
  },
  "oneOf": [
    {
      "required": [
        "payload"
      ],
      "properties": {
        "payload": {
          "description": "Decoded JSON payload form (preferred for Core payloads and readable messages)."
        }
      },
      "not": {
        "required": [
          "payload_b64"
        ]
      }
    },
    {
      "required": [
        "payload_b64"
      ],
      "properties": {
        "payload_b64": {
          "type": "string",
          "description": "Opaque payload bytes encoded as base64 (use when payload is opaque or binary).",
          "contentEncoding": "base64"
        }
      },
      "not": {
        "required": [
          "payload"
        ]
      }
    }
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "message_type": {
            "const": "Signal"
          }
        },
        "required": [
          "message_type"
        ]
      },
      "then": {
        "properties": {
          "mode": {
            "maxLength": 0
          },
          "session_id": {
            "maxLength": 0
          },
          "payload": {
            "$ref": "#/$defs/SignalPayload"
          }
        }
      },
      "else": {
        "properties": {
          "mode": {
            "minLength": 1
          },
          "session_id": {
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "message_type": {
            "const": "SessionStart"
          }
        },
        "required": [
          "message_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/SessionStartPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "message_type": {
            "const": "SessionCancel"
          }
        },
        "required": [
          "message_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/SessionCancelPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "message_type": {
            "const": "Commitment"
          }
        },
        "required": [
          "message_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/CommitmentPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "message_type": {
            "const": "Progress"
          }
        },
        "required": [
          "message_type"
        ]
      },
      "then": {
        "properties": {
          "mode": {
            "minLength": 1
          },
          "session_id": {
            "minLength": 1
          },
          "payload": {
            "$ref": "#/$defs/ProgressPayload"
          }
        }
      }
    }
  ],
  "$defs": {
    "Base64Bytes": {
      "type": "string",
      "description": "Protobuf bytes mapped to base64 string in JSON.",
      "contentEncoding": "base64"
    },
    "Root": {
      "type": "object",
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1,
          "description": "Absolute URI boundary."
        },
        "name": {
          "type": "string"
        }
      }
    },
    "SignalPayload": {
      "type": "object",
      "required": [
        "signal_type"
      ],
      "properties": {
        "signal_type": {
          "type": "string",
          "minLength": 1
        },
        "data": {
          "$ref": "#/$defs/Base64Bytes"
        },
        "confidence": {
          "type": "number"
        },
        "correlation_session_id": {
          "type": "string"
        }
      }
    },
    "SessionStartPayload": {
      "type": "object",
      "required": [
        "ttl_ms",
        "mode_version",
        "configuration_version"
      ],
      "properties": {
        "intent": {
          "type": "string"
        },
        "participants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mode_version": {
          "type": "string",
          "minLength": 1
        },
        "configuration_version": {
          "type": "string",
          "minLength": 1
        },
        "ttl_ms": {
          "type": "integer",
          "minimum": 1,
          "description": "Session TTL in milliseconds."
        },
        "context": {
          "$ref": "#/$defs/Base64Bytes"
        },
        "roots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Root"
          }
        },
        "policy_version": {
          "type": "string"
        }
      }
    },
    "SessionCancelPayload": {
      "type": "object",
      "required": [
        "reason"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "cancelled_by": {
          "type": "string"
        }
      }
    },
    "CommitmentPayload": {
      "type": "object",
      "required": ["commitment_id"],
      "properties": {
        "commitment_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "description": "Action identifier describing the outcome. Mode RFCs define the normative vocabulary (e.g., 'decision.approved', 'task.failed', 'quorum.rejected')."
        },
        "authority_scope": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "mode_version": {
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "configuration_version": {
          "type": "string"
        },
        "outcome_positive": {
          "type": "boolean",
          "description": "True for positive/successful outcomes; false for definitive negative outcomes. Modes that allow negative commitments MUST set this field explicitly."
        }
      }
    },
    "ProgressPayload": {
      "type": "object",
      "properties": {
        "progress_token": {
          "type": "string",
          "description": "Token linking this progress update to a prior request."
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "description": "Current progress value."
        },
        "total": {
          "type": "number",
          "minimum": 0,
          "description": "Total work units (progress is relative to this value)."
        },
        "message": {
          "type": "string",
          "description": "Human-readable progress description."
        },
        "target_message_id": {
          "type": "string",
          "description": "The message_id of the request this progress relates to."
        }
      }
    }
  }
}
