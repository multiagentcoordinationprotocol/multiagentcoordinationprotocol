{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macp.dev/schemas/macp-mode-descriptor.schema.json",
  "title": "MACP Mode Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "mode_version",
    "title",
    "description",
    "determinism_class",
    "participant_model",
    "message_types",
    "terminal_message_types"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "mode_version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "determinism_class": {
      "type": "string",
      "enum": [
        "structural-only",
        "semantic-deterministic",
        "context-frozen",
        "non-deterministic"
      ]
    },
    "participant_model": {
      "type": "string",
      "minLength": 1
    },
    "message_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "terminal_message_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "schema_uris": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
