{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multiagentcoordinationprotocol.dev/schemas/macp-ack.schema.json",
  "title": "MACP Acknowledgement",
  "description": "Validates an Ack message in JSON form. See RFC-MACP-0001 Section 8.",
  "type": "object",
  "properties": {
    "message_id": {
      "type": "string",
      "minLength": 1,
      "description": "The message_id of the acknowledged envelope."
    },
    "accepted": {
      "type": "boolean",
      "description": "True if the envelope was accepted into session history."
    },
    "error": {
      "$ref": "#/$defs/MACPError",
      "description": "Present when accepted is false."
    }
  },
  "required": ["message_id", "accepted"],
  "$defs": {
    "MACPError": {
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Machine-readable error code." },
        "message": { "type": "string", "description": "Human-readable error message." },
        "details": { "type": "object", "description": "Additional structured error details." }
      },
      "required": ["code"]
    }
  }
}
