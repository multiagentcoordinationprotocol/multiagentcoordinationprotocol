{
  "$comment": "Example: Decision Mode session governed by a supermajority policy with veto. See RFC-MACP-0012.",
  "session_id": "sess-policy-demo-001",
  "mode": "macp.mode.decision.v1",
  "policy_version": "policy.fraud.supermajority-veto",
  "policy_definition": {
    "policy_id": "policy.fraud.supermajority-veto",
    "mode": "macp.mode.decision.v1",
    "schema_version": 1,
    "description": "Supermajority (67%) with blocking-objection veto and 2-voter quorum",
    "rules": {
      "voting": {
        "algorithm": "supermajority",
        "threshold": 0.67,
        "quorum": { "type": "count", "value": 2 }
      },
      "objection_handling": {
        "block_severity_vetoes": true,
        "veto_threshold": 1
      },
      "evaluation": {
        "minimum_confidence": 0.0,
        "required_before_voting": false
      },
      "commitment": {
        "authority": "initiator_only",
        "require_vote_quorum": true
      }
    }
  },
  "participants": ["coordinator", "fraud-agent", "growth-agent", "compliance-agent"],
  "transcript": [
    {
      "seq": 1,
      "message_type": "SessionStart",
      "sender": "coordinator",
      "payload": {
        "intent": "Review high-value transaction for fraud",
        "participants": ["coordinator", "fraud-agent", "growth-agent", "compliance-agent"],
        "mode_version": "1.0.0",
        "configuration_version": "config.default",
        "policy_version": "policy.fraud.supermajority-veto",
        "ttl_ms": 60000
      },
      "note": "Runtime resolves 'policy.fraud.supermajority-veto' from registry and stores PolicyDefinition on session."
    },
    {
      "seq": 2,
      "message_type": "Proposal",
      "sender": "coordinator",
      "payload": {
        "proposal_id": "p1",
        "option": "approve-transaction",
        "rationale": "Transaction $12,500 from new device in known merchant category"
      }
    },
    {
      "seq": 3,
      "message_type": "Evaluation",
      "sender": "fraud-agent",
      "payload": {
        "proposal_id": "p1",
        "recommendation": "APPROVE",
        "confidence": 0.82,
        "reason": "Device fingerprint is new but IP geolocation matches cardholder region"
      }
    },
    {
      "seq": 4,
      "message_type": "Evaluation",
      "sender": "growth-agent",
      "payload": {
        "proposal_id": "p1",
        "recommendation": "APPROVE",
        "confidence": 0.91,
        "reason": "Customer lifetime value $45K, merchant category is consistent with spending history"
      }
    },
    {
      "seq": 5,
      "message_type": "Evaluation",
      "sender": "compliance-agent",
      "payload": {
        "proposal_id": "p1",
        "recommendation": "REVIEW",
        "confidence": 0.65,
        "reason": "Amount exceeds single-transaction threshold for new device; manual review suggested"
      }
    },
    {
      "seq": 6,
      "message_type": "Vote",
      "sender": "fraud-agent",
      "payload": {
        "proposal_id": "p1",
        "vote": "approve",
        "reason": "Risk score within tolerance"
      }
    },
    {
      "seq": 7,
      "message_type": "Vote",
      "sender": "growth-agent",
      "payload": {
        "proposal_id": "p1",
        "vote": "approve",
        "reason": "Customer value justifies approval"
      }
    },
    {
      "seq": 8,
      "message_type": "Vote",
      "sender": "compliance-agent",
      "payload": {
        "proposal_id": "p1",
        "vote": "reject",
        "reason": "Threshold exceeded on new device"
      }
    },
    {
      "seq": 9,
      "message_type": "Commitment",
      "sender": "coordinator",
      "payload": {
        "commitment_id": "c1",
        "action": "approve-transaction",
        "authority_scope": "transaction_review",
        "reason": "Supermajority achieved: 2 approve, 1 reject (67% threshold met). No blocking objections.",
        "mode_version": "1.0.0",
        "policy_version": "policy.fraud.supermajority-veto",
        "configuration_version": "config.default"
      },
      "note": "Policy evaluation: quorum met (3 votes >= 2 required), supermajority met (2/3 = 67% >= 67% threshold), no blocking objections. Commitment ACCEPTED."
    }
  ],
  "outcome": {
    "state": "RESOLVED",
    "policy_evaluation": {
      "quorum_met": true,
      "votes_cast": 3,
      "quorum_required": 2,
      "threshold_met": true,
      "approve_fraction": 0.67,
      "threshold_required": 0.67,
      "blocking_objections": 0,
      "veto_active": false,
      "decision": "ALLOW"
    }
  }
}
